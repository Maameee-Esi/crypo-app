# Suppress Vite client warnings during development
VITE_SUPPRESS_WARNINGS=true

# API Configuration
# In development: uses http://localhost:5000/api by default
# In production (Netlify): Set VITE_API_URL in Netlify Environment Variables
# Example: VITE_API_URL=https://your-backend.onrender.com/api
VITE_API_URL=https://crypo-app.onrender.com/api
