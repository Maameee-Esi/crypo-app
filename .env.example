# Frontend Environment Variables Example
# Copy this file to .env and fill in the values

# Suppress Vite client warnings during development
VITE_SUPPRESS_WARNINGS=true

# API Configuration
# In development: Set to your local backend URL or use the hosted backend
# In production (Netlify): Set this in Netlify Environment Variables
VITE_API_URL=https://crypo-app.onrender.com/api
